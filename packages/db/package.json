{
  "name": "@stardew/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint src prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:sync-wiki-items": "node scripts/sync-wiki-supplemental-items.mjs && node scripts/generate-game-item-seed-files.mjs",
    "db:validate-items": "node scripts/validate-game-items-against-wiki.mjs",
    "icons:download": "node scripts/download-item-icons.mjs",
    "icons:download:force": "node scripts/download-item-icons.mjs --force"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.17.0",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
